{
    "github.copilot.advanced": {
      "context": {
      "excludedFileTypes": ["dotenv", "env", "yml"]
      }
    },
    "emmet.triggerExpansionOnTab": true,
    "emmet.includeLanguages": {
      "django-html": "html"
    },
    "editor.linkedEditing": true,
    "tabnine.experimentalAutoImports": true,
    "editor.fontFamily": "source code pro",
    "editor.fontLigatures": false,
    "debug.console.fontFamily": "",
    "workbench.productIconTheme": "developer-icons",
    "workbench.colorCustomizations": {},
    "dayNightThemeSwitcher.nightTheme": "Night Owl",
    "dayNightThemeSwitcher.dayTheme": "Min Light",
    "terminal.integrated.fontSize": 14,
    "explorer.sortOrder": "filesFirst",
    "security.workspace.trust.untrustedFiles": "open",
    "markdown.extension.preview.autoShowPreviewToSide": true,
    "cSpell.userWords": [
      "ilike",
      "inplace",
      "pyperclip",
      "SENDGRID",
      "skipfooter"
    ],
    "explorer.confirmDelete": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "[python]": {
      "editor.defaultFormatter": "ms-python.black-formatter",
      "editor.tabSize": 4,
      "editor.insertSpaces": true
    },
    "editor.detectIndentation": false,
    "black-formatter.args": ["-S"],
    "flake8.args": [
      "--max-line-length=120",
      "--ignore=E203,W503,W504,F401"
    ],
    "python.linting.enabled": true,
    "python.linting.mypyEnabled": true,
    "python.autoComplete.extraPaths": [
      "${workspaceFolder}/venv/Lib/site-packages"
    ],
    "python.analysis.extraPaths": [
      "${workspaceFolder}/venv/Lib/site-packages"
    ],
    "html.format.contentUnformatted": "",
    "html.format.extraLiners": "",
    "editor.minimap.enabled": false,
    "notebook.output.scrolling": true,
    "notebook.output.textLineLimit": 500,
    "workbench.colorTheme": "Night Owl (No Italics)",
    "extensions.experimental.affinity": {
      "asvetliakov.vscode-neovim": 1
    },
    "terminal.integrated.fontFamily": "SauceCodePro Nerd Font Mono",
    "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
    "vscode-neovim.neovimInitVimPaths.darwin": "/Users/junkakishima/.config/nvim/lua/jun/core/init.lua",
    "editor.fontSize": 15,
    "diffEditor.ignoreTrimWhitespace": false,
    "workbench.activityBar.location": "hidden",
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3"
  }
  